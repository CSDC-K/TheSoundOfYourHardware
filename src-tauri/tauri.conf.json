{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "thesoundofyourhardware",
  "version": "0.1.0",
  "identifier": "com.kuzeyc.thesoundofyourhardware",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "The Sound Of Your Hardware",
        "width": 800,
        "height": 600,
        "resizable" : false,
        "fullscreen" : false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "resources": [
      "../src/assets/close.png",
      "../src/assets/list.png",
      "../src/assets/refresh.png",
      "../src/assets/doc.png",
      "../src/assets/play.png",
      "../src/assets/pause.png",
      "../src/assets/delete.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
